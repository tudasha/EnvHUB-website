// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int      @id @default(autoincrement())
  email         String   @unique
  name          String?
  password_hash String
  role          Role     @default(USER)
  subscription  String   @default("free")
  modules       Json     @default("[]")
  location      String?  @default("Cluj-Napoca")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  orders         Order[]
  cartItems      CartItem[]
  sensorReadings SensorReading[]
  aiMessages     AiMessage[]
  communityHubs  CommunityHub[]
  calendarEvents CalendarEvent[]
  healthSteps    HealthStep[]
  healthMeals    HealthMeal[]

  @@map("users")
}

model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String
  price       Float
  imageUrl    String
  category    Category
  stock       Int      @default(100)
  tags        String[]
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())

  cartItems  CartItem[]
  orderItems OrderItem[]

  @@map("products")
}

model CartItem {
  id        String @id @default(cuid())
  quantity  Int    @default(1)
  userId    Int
  productId String

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@unique([userId, productId])
  @@map("cart_items")
}

model Order {
  id        String      @id @default(cuid())
  status    OrderStatus @default(PENDING)
  total     Float
  userId    Int
  address   String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user  User        @relation(fields: [userId], references: [id])
  items OrderItem[]

  @@map("orders")
}

model OrderItem {
  id        String @id @default(cuid())
  quantity  Int
  price     Float
  orderId   String
  productId String

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

enum Role {
  USER
  ADMIN
}

enum Category {
  SENSOR
  ACTUATOR
  GATEWAY
  HUB
  KIT
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

model SensorReading {
  id         Int      @id @default(autoincrement())
  userId     Int?     @map("user_id")
  sensorType String   @map("sensor_type")
  value      Float?
  unit       String?
  recordedAt DateTime @default(now()) @map("recorded_at")

  user User? @relation(fields: [userId], references: [id])

  @@map("sensor_readings")
}

model AiMessage {
  id        Int      @id @default(autoincrement())
  userId    Int?     @map("user_id")
  role      String
  content   String
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@map("ai_messages")
}

model CommunityHub {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  name      String
  ownerId   Int?     @map("owner_id")
  members   Json?    @default("[]")
  createdAt DateTime @default(now()) @map("created_at")

  owner User? @relation(fields: [ownerId], references: [id])

  @@map("community_hubs")
}

model CalendarEvent {
  id          Int       @id @default(autoincrement())
  userId      Int?      @map("user_id")
  title       String
  description String?
  startTime   DateTime? @map("start_time")
  endTime     DateTime? @map("end_time")
  color       String?   @default("#6366f1")

  user User? @relation(fields: [userId], references: [id])

  @@map("calendar_events")
}

model HealthStep {
  id         Int      @id @default(autoincrement())
  userId     Int?     @map("user_id")
  steps      Int      @default(0)
  goal       Int      @default(10000)
  recordedAt DateTime @default(now()) @map("recorded_at")

  user User? @relation(fields: [userId], references: [id])

  @@map("health_steps")
}

model HealthMeal {
  id         Int      @id @default(autoincrement())
  userId     Int?     @map("user_id")
  name       String
  icon       String?  @default("🍽️")
  calories   Float?   @default(0)
  protein    Float?   @default(0)
  carbs      Float?   @default(0)
  fat        Float?   @default(0)
  mealType   String?  @default("snack") @map("meal_type")
  recordedAt DateTime @default(now()) @map("recorded_at")

  user User? @relation(fields: [userId], references: [id])

  @@map("health_meals")
}
